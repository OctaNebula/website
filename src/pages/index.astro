---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import pfp from '../assets/pfp.jpg';

const all = await getCollection('entries');
all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pinned = all.filter((e) => e.data.pinned);
const feed = all.filter((e) => !e.data.pinned);

const tags = ['all', 'shipped', 'wip', 'writing', 'note', 'release'] as const;

function fmtDate(d: Date) {
  return d.toISOString().slice(0, 10);
}

function fmtNum(n: number) {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, '') + 'K';
  return String(n);
}

// Build-time fetch: pull current visit count + active player count for any
// pinned card whose entry id appears here. Fails silently per-game so a
// network hiccup never breaks the build.
const buildISO = new Date().toISOString();

const robloxPlaces: Record<string, number> = {
  'mafia-pinned': 113232329524315,
  'steel-crossfire-pinned': 133197203959042,
};

const liveStats: Record<string, { visits: number; playing: number }> = {};
await Promise.all(
  Object.entries(robloxPlaces).map(async ([entryId, placeId]) => {
    try {
      const u = await fetch(`https://apis.roblox.com/universes/v1/places/${placeId}/universe`);
      const { universeId } = await u.json();
      const g = await fetch(`https://games.roblox.com/v1/games?universeIds=${universeId}`);
      const { data } = await g.json();
      if (data?.[0]) {
        liveStats[entryId] = { visits: data[0].visits, playing: data[0].playing };
      }
    } catch {
      // skip this game
    }
  })
);
---
<Base>
  <header class="hero">
    <div class="hero-top">
      <Image class="pfp" src={pfp} alt="Octavian" width={144} height={144} loading="eager" />
      <div class="hero-text">
        <div class="name-row">
          <h1>Octavian</h1>
          <span class="alias">@octanebula</span>
        </div>
        <p class="bio">
          19, CS undergrad in Croatia. Co-owner of
          <a href="https://www.roblox.com/communities/5670504/TOPLINE-STUDIOS-INC"><strong>Topline Studios</strong></a>,
          UI designer at
          <a href="https://www.roblox.com/communities/33895110/Marmots-Oven"><strong>Marmot's Oven</strong></a>.
          I make Roblox games and write code.
        </p>
        <nav class="socials">
          <a href="https://twitter.com/octanebula">xitter</a>
          <a href="https://github.com/octanebula">github</a>
          <a href="https://www.roblox.com/users/162871269/profile">roblox</a>
          <span class="wip-email">email<span class="wip-bubble">wip!</span></span>
        </nav>
      </div>
    </div>
  </header>

  {pinned.length > 0 && (
    <section class="pinned">
      <h2 class="section-label">// pinned</h2>
      <ul class="entries">
        {pinned.map((entry) => (
          <li class="entry">
            <div class="entry-meta">
              <time datetime={entry.data.date.toISOString()}>{fmtDate(entry.data.date)}</time>
              <span class={`tag tag-${entry.data.tag}`}>{entry.data.tag}</span>
            </div>
            <h3 class="entry-title">
              {entry.data.link
                ? <a href={entry.data.link}>{entry.data.title}</a>
                : entry.data.title}
            </h3>
            {liveStats[entry.id] && (
              <div class="live-stats">
                <span class="stat"><strong>{fmtNum(liveStats[entry.id].visits)}</strong> visits</span>
                <span class="stat"><span class="live-dot"></span><strong>{fmtNum(liveStats[entry.id].playing)}</strong> playing</span>
                <span class="info-wrap">
                  <svg class="info-icon" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="5" r="0.8" fill="currentColor"/></svg>
                  <span class="info-tip" data-build={buildISO}>last updated: just now</span>
                </span>
              </div>
            )}
            <div class="entry-body" set:html={entry.rendered?.html ?? ''} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="feed">
    <div class="feed-header">
      <h2 class="section-label">// feed</h2>
      <div class="filters">
        {tags.map((t) => <button class="filter" data-tag={t}>{t}</button>)}
      </div>
    </div>
    <ul class="entries">
      {feed.map((entry) => (
        <li class="entry" data-tag={entry.data.tag}>
          <div class="entry-meta">
            <time datetime={entry.data.date.toISOString()}>{fmtDate(entry.data.date)}</time>
            <span class={`tag tag-${entry.data.tag}`}>{entry.data.tag}</span>
          </div>
          <h3 class="entry-title">
            {entry.data.link
              ? <a href={entry.data.link}>{entry.data.title}</a>
              : entry.data.title}
          </h3>
          <div class="entry-body" set:html={entry.rendered?.html ?? ''} />
        </li>
      ))}
    </ul>
  </section>
</Base>

<script>
  // compute relative "X ago" for build timestamps
  function timeAgo(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const s = Math.floor(diff / 1000);
    if (s < 60) return 'just now';
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    return `${d}d ago`;
  }
  document.querySelectorAll<HTMLElement>('.info-tip[data-build]').forEach((tip) => {
    const iso = tip.dataset.build;
    if (iso) tip.textContent = `last updated: ${timeAgo(iso)}`;
  });

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter');
  const items = document.querySelectorAll<HTMLLIElement>('.feed .entry');
  let active = 'all';
  buttons.forEach((b) => {
    if (b.dataset.tag === active) b.classList.add('on');
    b.addEventListener('click', () => {
      active = b.dataset.tag || 'all';
      buttons.forEach((x) => x.classList.toggle('on', x.dataset.tag === active));
      items.forEach((it) => {
        const show = active === 'all' || it.dataset.tag === active;
        it.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .hero {
    position: relative;
    margin-bottom: 3rem;
    padding: 1.4rem 0.5rem;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: -10% -8%;
    background: radial-gradient(
      ellipse 90% 85% at 50% 50%,
      rgba(7, 9, 26, 0.88) 0%,
      rgba(7, 9, 26, 0.6) 45%,
      transparent 80%
    );
    filter: blur(20px);
    z-index: -1;
    pointer-events: none;
  }
  .hero-top { display: flex; gap: 1.1rem; align-items: center; position: relative; }
  .pfp {
    width: 72px; height: 72px; border-radius: 50%;
    border: 1px solid var(--border);
    object-fit: cover; flex-shrink: 0;
    background: var(--bg-elev);
  }
  .hero-text { min-width: 0; }
  .name-row { display: flex; align-items: center; gap: 0.6rem; }
  h1 { font-size: 1.6rem; margin: 0; line-height: 1; }
  .alias {
    color: var(--fg-dim);
    font-weight: 400;
    font-family: var(--mono);
    font-size: 0.95rem;
    line-height: 1;
  }
  .bio { color: var(--fg); margin: 0.6rem 0 1rem; }
  .bio strong { color: var(--accent); font-weight: 600; }
  .socials { display: flex; gap: 1.1rem; font-family: var(--mono); font-size: 0.86rem; }
  .socials a { color: var(--fg-dim); }
  .socials a:hover { color: var(--accent); }

  .section-label {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-dim);
    text-transform: lowercase;
    margin: 2.5rem 0 1rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    background: rgba(19, 20, 24, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .feed-header { display: flex; align-items: baseline; justify-content: space-between; gap: 0.65rem; flex-wrap: wrap; }
  .filters { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  @media (max-width: 600px) {
    .feed-header { flex-direction: column; align-items: flex-start; }
  }
  .filter {
    background: rgba(19, 20, 24, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--border); color: var(--fg-dim);
    font-family: var(--mono); font-size: 0.72rem; padding: 0.2rem 0.55rem;
    border-radius: 999px; cursor: pointer; text-transform: lowercase;
    transition: color 140ms ease, background 140ms ease, border-color 140ms ease;
  }
  .filter:hover { color: var(--fg); }
  .filter.on { background: var(--fg); color: var(--bg); border-color: var(--fg); }

  .entries { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
  .entry {
    padding: 1.1rem 1.25rem;
    background: rgba(19, 20, 24, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
  }
  .entry:hover {
    transform: translateY(-2px);
    border-color: #2f3540;
    background: rgba(22, 24, 30, 0.85);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(124, 156, 255, 0.08);
  }
  .entry-meta { display: flex; align-items: center; gap: 0.75rem; font-family: var(--mono); font-size: 0.74rem; color: var(--fg-dim); margin-bottom: 0.35rem; }
  .entry-title { margin: 0 0 0.4rem; font-size: 1.05rem; }
  .entry-body { color: var(--fg); font-size: 0.94rem; }
  .entry-body :global(p) { margin: 0.4rem 0; }
  .entry-body :global(p:first-child) { margin-top: 0; }

  .tag {
    display: inline-block; padding: 0.05rem 0.45rem;
    border-radius: 3px; font-size: 0.68rem; text-transform: lowercase;
    border: 1px solid currentColor;
  }
  .tag-shipped { color: var(--tag-shipped); }
  .tag-wip { color: var(--tag-wip); }
  .tag-writing { color: var(--tag-writing); }
  .tag-note { color: var(--tag-note); }
  .tag-release { color: var(--tag-release); }

  .pinned .entry-title::before {
    content: '★ ';
    color: var(--tag-wip);
    font-size: 0.85em;
  }

  .live-stats {
    display: flex;
    gap: 1rem;
    margin: 0.1rem 0 0.5rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-dim);
    align-items: center;
  }
  .live-stats .stat { display: inline-flex; align-items: center; gap: 0.35rem; }
  .live-stats strong { color: var(--fg); font-weight: 600; }
  .live-dot {
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--tag-shipped);
    box-shadow: 0 0 6px var(--tag-shipped);
    animation: live-pulse 1.8s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 0.6; transform: scale(0.9); }
    50%      { opacity: 1;   transform: scale(1.1); }
  }

  .info-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-left: -0.2rem;
  }
  .info-icon {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--fg-dim);
    cursor: help;
    flex-shrink: 0;
  }
  .info-tip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    margin-bottom: 0.5rem;
    transform: translate(-50%, 4px);
    padding: 0.25rem 0.55rem;
    background: rgba(16, 20, 42, 0.95);
    border: 1px solid var(--border);
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--fg);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .info-tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--border);
  }
  .info-wrap:hover .info-tip,
  .info-wrap:focus-within .info-tip {
    opacity: 1;
    transform: translate(-50%, 0);
  }
</style>
