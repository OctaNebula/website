---
import FloatingLines from '../components/FloatingLines.astro';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'octanebula.dev',
  description = "personal site of @octanebula. verified roblox dev, ui designer, co-owner of topline studios, perpetually-suffering CS undergrad.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://octanebula.dev').toString();

// Site version. Bump manually.
const version = 'v1.0.3';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="darkreader-lock" />
    <meta name="theme-color" content="#0f1740" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="octanebula.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@octanebula" />
    <meta name="twitter:creator" content="@octanebula" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <FloatingLines />
    <nav class="topbar">
      <a class="brand" href="/">octanebula.dev</a>
      <div class="topbar-links">
        <a href="/">log</a>
        <a href="/about">about</a>
        <a href="/commissions">commissions</a>
        <a href="/gallery">ui gallery</a>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <span>octanebula.dev</span>
      <span class="footer-right">
        <a id="sauce-link" class="sauce" href="https://github.com/octanebula/website">sauce</a>
        <span class="ver">{version}</span>
      </span>
    </footer>

    <div id="sauce-gate" class="sauce-gate" hidden>
      <div class="sauce-card">
        <div class="sauce-tag">⚠ ai slop warning</div>
        <h2 class="sauce-title">you sure about that?</h2>
        <p>
          fair warning: this entire site was vibe-coded with claude. the repo
          is mostly <code>.astro</code> files i barely read before merging.
        </p>
        <p>
          if you came here looking for clean handwritten code, beautifully
          architected components, or any sign of human suffering, you'll be
          disappointed.
        </p>
        <p class="sauce-fineprint">
          if you came here for proof that vibecoding can in fact ship a real
          website, welcome.
        </p>
        <a id="sauce-continue" class="sauce-btn" href="https://github.com/octanebula/website" target="_blank" rel="noopener">i'll risk it</a>
        <a id="sauce-bail" class="sauce-bail" href="#">nevermind, take me back</a>
      </div>
    </div>

    <script>
      const sauceLink = document.getElementById('sauce-link');
      const sauceGate = document.getElementById('sauce-gate');
      const sauceContinue = document.getElementById('sauce-continue');
      const sauceBail = document.getElementById('sauce-bail');

      const openGate = () => {
        if (!sauceGate) return;
        sauceGate.hidden = false;
        document.body.style.overflow = 'hidden';
        requestAnimationFrame(() => sauceGate.classList.add('open'));
      };
      const closeGate = () => {
        if (!sauceGate) return;
        sauceGate.classList.remove('open');
        document.body.style.overflow = '';
        setTimeout(() => { sauceGate.hidden = true; }, 220);
      };

      sauceLink?.addEventListener('click', (e) => {
        e.preventDefault();
        openGate();
      });
      sauceContinue?.addEventListener('click', () => {
        // let the link open, then close the gate
        setTimeout(closeGate, 100);
      });
      sauceBail?.addEventListener('click', (e) => {
        e.preventDefault();
        closeGate();
      });
      sauceGate?.addEventListener('click', (e) => {
        if (e.target === sauceGate) closeGate();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sauceGate && !sauceGate.hidden) closeGate();
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #07091a;
    --bg-elev: #10142a;
    --border: #22252b;
    --fg: #e6e6e6;
    --fg-dim: #8a8f98;
    --accent: #7c9cff;
    --tag-shipped: #5dd39e;
    --tag-wip: #f4b740;
    --tag-writing: #c792ea;
    --tag-note: #8a8f98;
    --tag-release: #7c9cff;
    --mono: ui-monospace, "JetBrains Mono", "SF Mono", Menlo, Consolas, monospace;
    --sans: -apple-system, system-ui, "Inter", Segoe UI, sans-serif;
  }
  * { box-sizing: border-box; }
  html {
    background:
      radial-gradient(ellipse 100% 70% at 50% 0%, #0f1740 0%, #07091a 55%, #05060f 100%);
    background-attachment: fixed;
  }
  html::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(180, 200, 255, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(180, 200, 255, 0.045) 1px, transparent 1px);
    background-size: 40px 40px, 40px 40px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 30%, #000 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 30%, #000 40%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }
  body { margin: 0; padding: 0; color: var(--fg); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
  body { max-width: 720px; margin: 0 auto; padding: 5.5rem 1.5rem 6rem; line-height: 1.55; position: relative; }

  .topbar {
    position: fixed; top: 0; left: 0; right: 0;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.85rem 1.5rem;
    background: rgba(11, 12, 14, 0.65);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 0.82rem;
    z-index: 10;
  }
  .topbar .brand { color: var(--fg); font-weight: 600; }
  .topbar .brand:hover { text-decoration: none; color: var(--accent); }
  .topbar-links { display: flex; gap: 1.25rem; }
  .topbar-links a { color: var(--fg-dim); }
  .topbar-links a:hover { color: var(--fg); text-decoration: none; }

  /* "email is not set up yet" stub */
  .wip-email {
    position: relative;
    color: var(--fg-dim);
    text-decoration: line-through;
    cursor: not-allowed;
  }
  .wip-bubble {
    position: absolute;
    bottom: 100%;
    left: 50%;
    margin-bottom: 0.55rem;
    transform: translate(-50%, 4px);
    padding: 0.25rem 0.5rem;
    background: rgba(16, 20, 42, 0.95);
    border: 1px solid var(--border);
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg);
    text-decoration: none;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .wip-bubble::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--border);
  }
  .wip-email:hover .wip-bubble {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  @media (max-width: 600px) {
    .topbar { padding: 0.7rem 1rem; font-size: 0.78rem; }
    .topbar .brand { display: none; }
    .topbar-links { gap: 0.95rem; width: 100%; justify-content: space-between; }
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1, h2, h3 { font-weight: 600; letter-spacing: -0.01em; }
  hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .site-footer { display: flex; justify-content: space-between; margin-top: 4rem; padding-top: 1.25rem; border-top: 1px solid var(--border); color: var(--fg-dim); font-family: var(--mono); font-size: 0.78rem; }
  .footer-right { display: inline-flex; gap: 0.65rem; align-items: center; }
  .sauce {
    display: inline-block;
    line-height: 1;
    color: var(--fg-dim);
    text-decoration: none;
    border-bottom: 1px dotted currentColor;
    padding-bottom: 2px;
  }
  .sauce:hover {
    color: var(--fg);
    text-decoration: none;
    border-bottom-style: solid;
  }
  .ver::before { content: '· '; }

  /* sauce / ai slop warning gate */
  .sauce-gate {
    position: fixed; inset: 0; z-index: 300;
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem;
    background: rgba(5, 6, 15, 0.78);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    opacity: 0;
    transition: opacity 220ms ease, backdrop-filter 220ms ease;
  }
  .sauce-gate.open {
    opacity: 1;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .sauce-gate[hidden] { display: none; }
  .sauce-card {
    max-width: 480px;
    background: rgba(16, 20, 42, 0.92);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.6rem 1.6rem 1.4rem;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
    transform: scale(0.96);
    transition: transform 260ms cubic-bezier(0.2, 0.9, 0.3, 1.2);
  }
  .sauce-gate.open .sauce-card { transform: scale(1); }
  .sauce-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--tag-wip);
    border: 1px solid var(--tag-wip);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    margin-bottom: 0.85rem;
    text-transform: lowercase;
  }
  .sauce-title { margin: 0 0 0.85rem; font-size: 1.3rem; line-height: 1.25; color: var(--fg); }
  .sauce-card p { margin: 0.55rem 0; color: var(--fg); font-size: 0.92rem; line-height: 1.55; }
  .sauce-card code {
    font-family: var(--mono);
    background: rgba(7, 9, 26, 0.6);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.05rem 0.35rem;
    font-size: 0.85em;
  }
  .sauce-fineprint { color: var(--fg-dim) !important; font-size: 0.84rem !important; font-style: italic; }
  .sauce-btn {
    display: block;
    margin-top: 1rem;
    width: 100%;
    background: var(--accent);
    color: #07091a;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-family: var(--mono);
    font-size: 0.86rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: filter 140ms ease, transform 140ms ease;
  }
  .sauce-btn:hover { filter: brightness(1.1); transform: translateY(-1px); text-decoration: none; }
  .sauce-bail {
    display: block;
    text-align: center;
    margin-top: 0.75rem;
    color: var(--fg-dim);
    font-family: var(--mono);
    font-size: 0.74rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sauce-bail:hover { color: var(--fg); }
</style>
